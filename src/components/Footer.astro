---
import EditLink from "@astrojs/starlight/components/EditLink.astro";
import LastUpdated from "@astrojs/starlight/components/LastUpdated.astro";
import Pagination from "@astrojs/starlight/components/Pagination.astro";
---

<footer class="sl-flex">
  <div class="meta sl-flex">
    <EditLink />
    <LastUpdated />
  </div>
  <Pagination />
  <p class="lemon-credit">
    <span>Anderson Lima</span>
    <span aria-hidden="true">|</span>
    <a href="https://lemon.dev.br">https://lemon.dev.br</a>
  </p>
</footer>

<style>
  @layer starlight.core {
    footer {
      flex-direction: column;
      gap: 1.5rem;
    }

    .meta {
      gap: 0.75rem 3rem;
      justify-content: space-between;
      flex-wrap: wrap;
      margin-top: 3rem;
      font-size: var(--sl-text-sm);
      color: var(--sl-color-gray-3);
    }

    .meta > :global(p:only-child) {
      margin-inline-start: auto;
    }

    .lemon-credit {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin: 1.5rem auto;
      font-size: var(--sl-text-sm);
      color: var(--sl-color-gray-3);
    }

    .lemon-credit span:first-child {
      color: var(--sl-color-gray-2);
      font-weight: 700;
    }

    .lemon-credit a {
      color: var(--sl-color-accent-high);
      text-decoration: none;
    }

    .lemon-credit a:hover {
      color: var(--sl-color-white);
      text-decoration: underline;
      text-underline-offset: 0.2em;
    }
  }
</style>

<script>
  import { 
    analytics, 
    ANALYTICS_ID, 
    GTMAnalyticsProvider, 
    GA4AnalyticsProvider, 
    ConsoleAnalyticsProvider 
  } from "../lib/analytics";

  // 1. Initialize the correct provider based on the ANALYTICS_ID
  function initAnalytics() {
    if (ANALYTICS_ID && !ANALYTICS_ID.includes("PLACEHOLDER")) {
      if (ANALYTICS_ID.startsWith("GTM-")) {
        analytics.setProvider(new GTMAnalyticsProvider(ANALYTICS_ID));
      } else if (ANALYTICS_ID.startsWith("G-")) {
        analytics.setProvider(new GA4AnalyticsProvider(ANALYTICS_ID));
      } else {
        analytics.setProvider(new ConsoleAnalyticsProvider());
      }
    } else {
      // Development mode fallback
      analytics.setProvider(new ConsoleAnalyticsProvider());
    }
  }

  // 2. Track page view of the current page
  function trackCurrentPage() {
    analytics.trackPageView(window.location.pathname, document.title);
  }

  // 3. Track sidebar/menu clicks
  function setupMenuTracking() {
    document.addEventListener("click", (event) => {
      const target = event.target as HTMLElement;
      const link = target.closest("a");
      
      if (!link) return;

      // Check if the link clicked is inside the sidebar pane (menu item)
      const isSidebarLink = !!link.closest(".sidebar-pane");

      if (isSidebarLink) {
        analytics.trackEvent("menu_click", {
          menu_item_name: link.textContent?.trim() || "",
          menu_item_url: link.getAttribute("href") || "",
          page_path: window.location.pathname
        });
      }
    });
  }

  // Execute initialization and tracking on client load
  try {
    initAnalytics();
    trackCurrentPage();
    setupMenuTracking();

    // Listen for client-side navigation events (e.g. Astro View Transitions)
    document.addEventListener("astro:after-swap", () => {
      trackCurrentPage();
    });
  } catch (error) {
    console.error("[Analytics] Error in tracking script:", error);
  }
</script>
